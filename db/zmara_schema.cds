namespace sap.materialMaster;

entity MaterialMaster{

    MATNR : String(20);   //Material Number
    MTART : String(4);    //Material Type
    MBRSH : String(1);   //Industry Sector
    LAEDA : Date;       //Last Change Date
    PSTAT : String(15);   //Material Status
    MATKL : String(10);  //Material Group

}